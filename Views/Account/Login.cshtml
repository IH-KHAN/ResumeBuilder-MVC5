@using ResumeBuilder_1291763.Models
@model LoginViewModel
@{
    ViewBag.Title = "Log in";
}

<style>
    h2, h3, h4, .btn {
        font-family: 'Poppins', sans-serif;
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: #f8f9fa; /* Light grey background for contrast with the white card */
    }

    .login-card {
        border: none;
        border-radius: 12px;
    }

    .form-floating > label {
        color: #6c757d;
    }

    .form-control:focus {
        border-color: #000;
        box-shadow: 0 0 0 0.25rem rgba(0, 0, 0, 0.1);
    }
</style>

<div class="container py-1">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card login-card shadow-lg mt-4 bg-white">
                <div class="card-body p-5">

                    <div class="text-center mb-4">
                        <h3 class="fw-bold text-dark">Welcome Back</h3>
                        <p class="text-muted small">Enter your details to sign in</p>
                    </div>

                    <section id="loginForm">
                        @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { role = "form" }))
                        {
                            @Html.AntiForgeryToken()

                            if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger small py-2 mb-3">
                                    @Html.ValidationSummary(true, "", new { @class = "m-0" })
                                </div>
                            }

                            <div class="form-floating mb-3">
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "name@example.com", id = "floatingInputEmail" })
                                @Html.LabelFor(m => m.Email, "Email Address")
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                            </div>

                            <div class="form-floating mb-3">
                                @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Password", id = "floatingInputPass" })
                                @Html.LabelFor(m => m.Password, "Password")
                                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input", id = "rememberMeCheck" })
                                    <label class="form-check-label text-secondary small" for="rememberMeCheck">Remember me</label>
                                </div>
                                @* Uncomment if you have Forgot Password implemented
                                    <a href="@Url.Action("ForgotPassword", "Account")" class="small text-decoration-none text-muted">Forgot password?</a>
                                *@
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-dark btn-lg">Sign In</button>
                            </div>
                        }
                    </section>
                </div>

                <div class="card-footer bg-white border-0 text-center pb-4 pt-0">
                    <p class="small text-muted mb-0">
                        Don't have an account?
                        @Html.ActionLink("Create account", "Register", null, new { @class = "text-dark fw-bold text-decoration-none" })
                    </p>
                </div>
            </div>

            <div class="mt-4 text-center">
                <section id="socialLoginForm">
                    @Html.Partial("_ExternalLoginsListPartial", new ExternalLoginListViewModel { ReturnUrl = ViewBag.ReturnUrl })
                </section>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}