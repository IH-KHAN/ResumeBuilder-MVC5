@model IEnumerable<ResumeBuilder_1291763.Models.ApplicationUser>

@{ ViewBag.Title = "Manage Users"; }

<div class="container py-4">
    <h2 class="mb-4">System Users</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>Email / Username</th>
                <th>Current Roles</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>
                        @if (user.Roles.Any())
                        {
                            <span class="badge bg-info text-dark">Has Role</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No Role</span>
                        }
                    </td>
                    <td>
                        @Html.ActionLink("Manage Role", "ManageRoles", new { id = user.Id }, new { @class = "btn btn-sm btn-primary" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>